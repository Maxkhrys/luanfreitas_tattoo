---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Luan Freitas Tattoo — Award-Winning Black & Grey Realism, Dublin',
  description = 'Luan Freitas is an internationally awarded black & grey realism tattoo artist based in Dublin. View the portfolio and book a consultation.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/og-image.jpg', Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="tattoo artist Dublin, black and grey realism Dublin, award winning tattoo artist Dublin, realism tattoo Ireland, Luan Freitas tattoo"
    />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#f4f2ee" />

    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <div class="scroll-progress" id="scroll-progress" aria-hidden="true"></div>
    <div class="grain" aria-hidden="true"></div>
    <slot />
    <script>
      import '../scripts/main';
    </script>
  </body>
</html>
