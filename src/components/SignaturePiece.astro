---
import { Image } from 'astro:assets';
import archangelMichael from '../assets/portfolio/archangel-michael.png';
---

<section id="signature" class="signature bg-near-black" data-signature-section>
  <div class="signature__pin" data-signature-pin>
    <div class="signature__eyebrow-row">
      <p class="eyebrow">Signature Piece</p>
    </div>

    <div class="signature__frame" data-signature-frame>
      <Image
        class="signature__image"
        src={archangelMichael}
        alt="Realism forearm piece — Archangel Michael, wings and chains beneath a radiant halo"
        widths={[500, 900, 1400]}
        sizes="(min-width: 900px) 64rem, 100vw"
      />
    </div>

    <div class="signature__caption" data-signature-caption>
      <h3 class="signature__title">Archangel Michael</h3>
      <p class="signature__meta">Forearm &middot; black &amp; grey realism</p>
    </div>
  </div>
</section>

<style>
  .signature {
    position: relative;
    padding-block: clamp(4rem, 10vw, 7rem);
  }

  .signature__pin {
    width: 100%;
    max-width: var(--content-max);
    margin-inline: auto;
    padding-inline: var(--gutter);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.75rem;
  }

  .signature__eyebrow-row {
    text-align: center;
  }

  .signature__frame {
    width: min(100%, 34rem);
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: var(--radius-lg);
    will-change: transform, clip-path;
  }

  .signature__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1) contrast(1.05);
  }

  .signature__caption {
    text-align: center;
    opacity: 0;
    transform: translateY(16px);
  }

  .signature__title {
    font-size: var(--text-h3);
    font-weight: 500;
  }

  .signature__meta {
    margin-top: 0.35rem;
    font-size: var(--text-small);
    color: var(--ink-mid);
    letter-spacing: 0.03em;
  }

  @media (prefers-reduced-motion: reduce) {
    .signature__caption {
      opacity: 1;
      transform: none;
    }
  }
</style>
