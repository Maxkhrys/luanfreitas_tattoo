---
import { Image } from 'astro:assets';
import jokerSleeve from '../assets/portfolio/joker-sleeve.png';
import saintsSleeve from '../assets/portfolio/saints-sleeve.png';
import virginMary from '../assets/portfolio/virgin-mary-rose.png';
import jesusCrown from '../assets/portfolio/jesus-crown-of-thorns.png';
import apePortrait from '../assets/portfolio/ape-portrait.png';
import archangelMichael from '../assets/portfolio/archangel-michael.png';
import marbleGoddess from '../assets/portfolio/marble-goddess.png';
import medusa from '../assets/portfolio/medusa.png';
import jokerPortrait from '../assets/portfolio/joker-portrait.png';

const pieces = [
  { src: jokerSleeve, title: 'Why So Serious', alt: 'Full sleeve realism — Joker mask sleeve', category: 'Portraits', tall: true },
  { src: saintsSleeve, title: 'The Gathering', alt: 'Full sleeve realism — Christ and the saints', category: 'Religious', tall: true },
  { src: medusa, title: 'Medusa', alt: 'Realism portrait — Medusa with serpents', category: 'Statuary', tall: false },
  { src: jesusCrown, title: 'Crown of Thorns', alt: 'Realism portrait — Christ crowned with thorns', category: 'Religious', tall: false },
  { src: apePortrait, title: 'The Fool', alt: 'Realism portrait — ape character study', category: 'Portraits', tall: false },
  { src: archangelMichael, title: 'Archangel Michael', alt: 'Realism piece — Archangel Michael', category: 'Religious', tall: true },
  { src: marbleGoddess, title: 'Marble Goddess', alt: 'Realism piece — marble goddess bust', category: 'Statuary', tall: false },
  { src: virginMary, title: 'Our Lady', alt: 'Realism portrait — Virgin Mary with rose', category: 'Religious', tall: false },
  { src: jokerPortrait, title: 'The Joker', alt: 'Realism portrait — Joker', category: 'Portraits', tall: false },
];

const categories = ['All', ...Array.from(new Set(pieces.map((p) => p.category)))];
---

<section id="portfolio" class="section bg-paper">
  <div class="wrap">
    <div class="portfolio__head">
      <p class="eyebrow" data-reveal>Portfolio</p>
      <div class="portfolio__head-row">
        <h2 class="portfolio__title" data-reveal-line>
          <span class="metallic-text" data-sheen>Selected<br />Work</span>
        </h2>
        <p class="lede portfolio__lede" data-reveal>
          A working archive of black &amp; grey realism — portraits, statuary and religious
          iconography. New pieces are added as photography comes in.
        </p>
      </div>
    </div>

    <div class="portfolio__filters" data-reveal role="tablist" aria-label="Filter portfolio by subject">
      {categories.map((c, i) => (
        <button
          type="button"
          class="portfolio__filter"
          class:list={[{ 'is-active': i === 0 }]}
          data-filter={c}
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
        >
          {c}
        </button>
      ))}
    </div>

    <div class="portfolio__grid" id="portfolio-grid">
      {pieces.map((p, i) => (
        <button
          type="button"
          class="portfolio__item"
          class:list={[{ 'portfolio__item--tall': p.tall }]}
          data-reveal
          data-category={p.category}
          data-index={i}
          aria-label={`Open ${p.title}, ${p.category}`}
        >
          <figure data-media class="portfolio__fig">
            <Image src={p.src} alt={p.alt} widths={[400, 700, 1000]} sizes="(min-width: 700px) 33vw, 50vw" loading="lazy" />
            <span class="portfolio__hairline" aria-hidden="true"></span>
            <span class="portfolio__index" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <figcaption class="portfolio__caption">
              <span class="portfolio__caption-title">{p.title}</span>
              <span class="portfolio__caption-cat">{p.category}</span>
            </figcaption>
          </figure>
        </button>
      ))}
    </div>
  </div>
</section>

<div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="Portfolio piece viewer" hidden>
  <button type="button" class="lightbox__close" id="lightbox-close" aria-label="Close">
    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M6 6l12 12M18 6L6 18" />
    </svg>
  </button>
  <figure class="lightbox__stage">
    <img id="lightbox-image" class="lightbox__image" src="" alt="" />
    <figcaption id="lightbox-caption" class="lightbox__caption"></figcaption>
  </figure>
</div>

<style>
  .portfolio__head-row {
    display: grid;
    gap: 1.5rem;
    margin-top: 1.25rem;
    align-items: end;
  }

  .portfolio__title {
    font-size: var(--text-h2);
    line-height: 0.95;
  }

  .portfolio__lede {
    max-width: 30rem;
  }

  .portfolio__filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: clamp(2.5rem, 5vw, 3.5rem);
  }

  .portfolio__filter {
    padding: 0.55em 1.15em;
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mid);
    border: 1px solid var(--line);
    border-radius: 999px;
    transition:
      color var(--dur) var(--ease),
      border-color var(--dur) var(--ease),
      background var(--dur) var(--ease);
  }

  .portfolio__filter:hover {
    color: var(--ink);
    border-color: var(--ink);
  }

  .portfolio__filter.is-active {
    color: var(--paper);
    background: var(--ink);
    border-color: var(--ink);
  }

  .portfolio__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(0.85rem, 1.8vw, 1.5rem);
    margin-top: clamp(2rem, 4vw, 3rem);
  }

  .portfolio__item {
    text-align: left;
    display: block;
  }

  .portfolio__item[hidden] {
    display: none;
  }

  .portfolio__fig {
    position: relative;
    cursor: pointer;
    aspect-ratio: 3 / 4;
    background: var(--mist);
  }

  .portfolio__fig :global(img) {
    width: 100%;
    height: 100%;
  }

  .portfolio__item:hover .portfolio__fig :global(img) {
    transform: scale(1.05);
    filter: grayscale(0.55) contrast(1.05);
  }

  /* Metallic hairline frame fades in on hover */
  .portfolio__hairline {
    position: absolute;
    inset: 0.6rem;
    border: 1px solid transparent;
    border-radius: 2px;
    opacity: 0;
    transform: scale(1.02);
    transition: opacity 0.5s var(--ease), transform 0.5s var(--ease-out-expo);
    pointer-events: none;
    z-index: 2;
  }

  .portfolio__item:hover .portfolio__hairline {
    opacity: 1;
    transform: scale(1);
    border-color: rgba(244, 242, 238, 0.55);
  }

  .portfolio__index {
    position: absolute;
    top: 0.85rem;
    left: 1rem;
    z-index: 3;
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.1em;
    color: rgba(244, 242, 238, 0.85);
    opacity: 0;
    transform: translateY(-6px);
    transition: opacity 0.45s var(--ease), transform 0.45s var(--ease-out-expo);
    pointer-events: none;
  }

  .portfolio__caption {
    position: absolute;
    left: 1rem;
    right: 1rem;
    bottom: 0.9rem;
    z-index: 3;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    pointer-events: none;
  }

  .portfolio__caption::before {
    content: '';
    position: absolute;
    inset: -1rem -1rem -0.9rem -1rem;
    background: linear-gradient(to top, rgba(13, 13, 15, 0.72), transparent);
    opacity: 0;
    transition: opacity 0.5s var(--ease);
    z-index: -1;
  }

  .portfolio__caption-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--paper);
    transform: translateY(8px);
    opacity: 0;
    transition: opacity 0.5s var(--ease), transform 0.5s var(--ease-out-expo);
  }

  .portfolio__caption-cat {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(244, 242, 238, 0.7);
    transform: translateY(8px);
    opacity: 0;
    transition: opacity 0.5s var(--ease) 0.05s, transform 0.5s var(--ease-out-expo) 0.05s;
  }

  .portfolio__item:hover .portfolio__index,
  .portfolio__item:hover .portfolio__caption-title,
  .portfolio__item:hover .portfolio__caption-cat {
    opacity: 1;
    transform: translateY(0);
  }

  .portfolio__item:hover .portfolio__caption::before {
    opacity: 1;
  }

  @media (min-width: 700px) {
    .portfolio__grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .portfolio__item--tall {
      grid-row: span 2;
    }
    .portfolio__item--tall .portfolio__fig {
      aspect-ratio: 3 / 6.15;
    }
    .portfolio__head-row {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* ---------- Lightbox ---------- */

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 3000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(1.5rem, 6vw, 4rem);
    background: rgba(244, 242, 238, 0.94);
    backdrop-filter: blur(8px);
  }

  .lightbox[hidden] {
    display: none;
  }

  .lightbox__stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    width: min(100%, 34rem);
  }

  .lightbox__image {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    filter: grayscale(1) contrast(1.05);
    box-shadow: 0 40px 80px -40px rgba(17, 17, 19, 0.5);
  }

  .lightbox__caption {
    font-family: var(--font-mono);
    font-size: var(--text-tiny);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-mid);
  }

  .lightbox__close {
    position: absolute;
    top: clamp(1rem, 3vw, 2rem);
    right: clamp(1rem, 3vw, 2rem);
    width: 2.75rem;
    height: 2.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ink);
    border: 1px solid var(--line);
    border-radius: 50%;
    transition: border-color var(--dur) var(--ease), transform var(--dur) var(--ease);
  }

  .lightbox__close:hover {
    border-color: var(--ink);
    transform: rotate(90deg);
  }
</style>

<script>
  const grid = document.getElementById('portfolio-grid');
  const filters = document.querySelectorAll<HTMLButtonElement>('.portfolio__filter');
  const items = grid ? Array.from(grid.querySelectorAll<HTMLButtonElement>('.portfolio__item')) : [];

  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      filters.forEach((b) => {
        b.classList.remove('is-active');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.add('is-active');
      btn.setAttribute('aria-selected', 'true');

      const filter = btn.dataset.filter;
      items.forEach((item) => {
        const match = filter === 'All' || item.dataset.category === filter;
        item.hidden = !match;
      });
    });
  });

  const lightbox = document.getElementById('lightbox');
  const lightboxImage = document.getElementById('lightbox-image') as HTMLImageElement | null;
  const lightboxCaption = document.getElementById('lightbox-caption');
  const lightboxClose = document.getElementById('lightbox-close');
  let lastFocused: HTMLElement | null = null;

  const openLightbox = (item: HTMLButtonElement) => {
    lastFocused = item;
    const img = item.querySelector('img');
    const title = item.querySelector('.portfolio__caption-title')?.textContent ?? '';
    const cat = item.querySelector('.portfolio__caption-cat')?.textContent ?? '';
    if (lightboxImage && img) {
      lightboxImage.src = img.currentSrc || img.src;
      lightboxImage.alt = img.alt;
    }
    if (lightboxCaption) lightboxCaption.textContent = `${title} — ${cat}`;
    lightbox?.removeAttribute('hidden');
    lightboxClose?.focus();
  };

  const closeLightbox = () => {
    lightbox?.setAttribute('hidden', '');
    lastFocused?.focus();
  };

  items.forEach((item) => {
    item.addEventListener('click', () => openLightbox(item));
  });

  lightboxClose?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });
  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && lightbox && !lightbox.hasAttribute('hidden')) closeLightbox();
  });
</script>
