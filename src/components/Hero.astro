<section id="hero" class="hero">
  <div class="hero__media">
    <video
      id="hero-video"
      class="hero__video"
      poster="/media/hero-poster.jpg"
      autoplay
      muted
      loop
      playsinline
      preload="none"
    >
      <source src="/media/hero-reel.mp4" type="video/mp4" />
    </video>

    <div id="hero-fallback" class="hero__fallback">
      <span class="placeholder-badge hero__fallback-badge">Placeholder — hero reel supplied</span>
      <span class="hero__fallback-note">Muted looping process footage will autoplay here on delivery.</span>
    </div>

    <div class="hero__overlay" aria-hidden="true"></div>
  </div>

  <div class="wrap hero__content">
    <p class="eyebrow hero__eyebrow" data-reveal-hero>Dublin &middot; Black &amp; Grey Realism</p>
    <h1 class="hero__mark">
      <span class="metallic-text" data-sheen data-sheen-immediate>Luan Freitas</span>
    </h1>
    <p class="hero__tagline" data-reveal-hero>Black &amp; grey realism. Dublin.</p>
  </div>

  <div class="hero__cue" aria-hidden="true">
    <span>Scroll</span>
    <span class="hero__cue-line"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--near-black);
  }

  .hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__video,
  .hero__fallback {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__video {
    animation: hero-kenburns 24s ease-in-out infinite alternate;
  }

  .hero__video.is-missing {
    display: none;
  }

  .hero__fallback {
    display: none;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-end;
    gap: 0.6rem;
    text-align: left;
    padding: clamp(1.5rem, 4vw, 2.5rem);
    background:
      radial-gradient(ellipse at 30% 20%, rgba(232, 234, 238, 0.06), transparent 55%),
      radial-gradient(ellipse at 75% 80%, rgba(255, 255, 255, 0.04), transparent 60%),
      linear-gradient(160deg, var(--graphite) 0%, var(--near-black) 65%);
    animation: hero-kenburns 24s ease-in-out infinite alternate;
  }

  .hero__fallback.is-active {
    display: flex;
  }

  .hero__fallback-badge {
    position: static;
  }

  .hero__fallback-note {
    max-width: 20rem;
    font-size: var(--text-tiny);
    color: var(--ink-faint);
  }

  @keyframes hero-kenburns {
    from {
      transform: scale(1);
    }
    to {
      transform: scale(1.08);
    }
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to bottom, rgba(10, 10, 10, 0.55) 0%, rgba(10, 10, 10, 0.35) 40%, rgba(10, 10, 10, 0.85) 100%),
      linear-gradient(to right, rgba(10, 10, 10, 0.4), rgba(10, 10, 10, 0.1) 40%, rgba(10, 10, 10, 0.4));
  }

  .hero__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.25rem;
  }

  .hero__eyebrow {
    color: var(--silver);
  }

  .hero__mark {
    font-size: var(--text-hero);
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1;
  }

  .hero__tagline {
    font-family: var(--font-body);
    font-size: clamp(1.05rem, 1.8vw, 1.4rem);
    color: var(--ink-soft);
    letter-spacing: 0.02em;
  }

  .hero__cue {
    position: absolute;
    bottom: clamp(1.5rem, 4vw, 2.5rem);
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    font-size: var(--text-tiny);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .hero__cue-line {
    width: 1px;
    height: 2.5rem;
    background: linear-gradient(to bottom, var(--silver-dim), transparent);
    animation: hero-cue 2.8s var(--ease-soft) infinite;
  }

  @keyframes hero-cue {
    0% {
      opacity: 0.2;
      transform: scaleY(0.3);
      transform-origin: top;
    }
    50% {
      opacity: 1;
      transform: scaleY(1);
      transform-origin: top;
    }
    100% {
      opacity: 0.2;
      transform: scaleY(0.3);
      transform-origin: top;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__video,
    .hero__fallback {
      animation: none;
    }
    .hero__cue-line {
      animation: none;
      opacity: 0.5;
    }
  }
</style>

<script>
  const video = document.getElementById('hero-video') as HTMLVideoElement | null;
  const fallback = document.getElementById('hero-fallback');
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const showFallback = () => {
    video?.classList.add('is-missing');
    fallback?.classList.add('is-active');
  };

  if (video && !reducedMotion) {
    video.addEventListener('error', showFallback, { once: true });
    video.preload = 'auto';
    video.load();
    video.play().catch(() => showFallback());

    // If nothing has started playing shortly after load, assume the
    // source is a placeholder/missing asset and fall back gracefully.
    window.setTimeout(() => {
      if (video.readyState === 0) showFallback();
    }, 2500);
  } else {
    showFallback();
  }
</script>
