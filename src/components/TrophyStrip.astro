---
const awards = [
  '[Placeholder: award name — year]',
  '[Placeholder: award name — year]',
  '[Placeholder: award name — year]',
];
---

<section class="trophy" aria-label="Awards and recognition">
  <div class="wrap trophy__inner">
    <span class="trophy__laurel" aria-hidden="true">
      <svg viewBox="0 0 32 32" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.1">
        <path d="M16 4c-3 4-3 12 0 16M16 4c3 4 3 12 0 16" />
        <path d="M9 8c-2 3-2 8 1 12M23 8c2 3 2 8-1 12" />
        <path d="M16 20l0 6" />
      </svg>
    </span>

    <p class="trophy__text">
      <span class="trophy__prefix">Internationally awarded</span>
      <span class="trophy__divider" aria-hidden="true">&middot;</span>
      {awards.map((a, i) => (
        <>
          <span class="trophy__award">{a}</span>
          {i < awards.length - 1 && <span class="trophy__divider" aria-hidden="true">&middot;</span>}
        </>
      ))}
    </p>

    <span class="trophy__laurel trophy__laurel--flip" aria-hidden="true">
      <svg viewBox="0 0 32 32" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.1">
        <path d="M16 4c-3 4-3 12 0 16M16 4c3 4 3 12 0 16" />
        <path d="M9 8c-2 3-2 8 1 12M23 8c2 3 2 8-1 12" />
        <path d="M16 20l0 6" />
      </svg>
    </span>
  </div>
</section>

<style>
  .trophy {
    position: relative;
    z-index: 2;
    background: var(--charcoal);
    border-block: 1px solid var(--line-soft);
    padding-block: 0.85rem;
  }

  .trophy__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.85rem;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .trophy__inner::-webkit-scrollbar {
    display: none;
  }

  .trophy__laurel {
    flex: none;
    color: var(--silver);
    opacity: 0.75;
  }

  .trophy__laurel--flip {
    transform: scaleX(-1);
  }

  .trophy__text {
    flex: none;
    display: flex;
    align-items: center;
    gap: 0.7rem;
    white-space: nowrap;
    font-size: var(--text-tiny);
    letter-spacing: 0.06em;
    color: var(--ink-mid);
  }

  .trophy__prefix {
    color: var(--silver);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 500;
  }

  .trophy__divider {
    color: var(--line);
  }

  .trophy__award {
    font-style: italic;
    color: var(--ink-faint);
  }
</style>
