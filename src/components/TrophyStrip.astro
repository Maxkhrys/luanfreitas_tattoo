---
// Credentials repeated across a slow marquee — understated proof, always
// moving so it reads as a living ticker rather than a static banner.
const credentials = [
  'Internationally Awarded',
  '[Award name — year]',
  'Black & Grey Realism',
  '[Convention / guest spot]',
  'Dublin, Ireland',
  '[Award name — year]',
  'Featured Artist',
  '[Publication / feature]',
];
---

<section class="trophy" aria-label="Awards and recognition">
  <div class="marquee" aria-hidden="true">
    <div class="marquee__track">
      {credentials.map((c) => (
        <span class="trophy__item">
          <svg class="trophy__laurel" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.2">
            <path d="M12 3c-2.2 3-2.2 9 0 12M12 3c2.2 3 2.2 9 0 12" />
            <path d="M7 6c-1.5 2.2-1.5 6 .8 9M17 6c1.5 2.2 1.5 6-.8 9" />
          </svg>
          {c}
        </span>
      ))}
      {credentials.map((c) => (
        <span class="trophy__item">
          <svg class="trophy__laurel" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.2">
            <path d="M12 3c-2.2 3-2.2 9 0 12M12 3c2.2 3 2.2 9 0 12" />
            <path d="M7 6c-1.5 2.2-1.5 6 .8 9M17 6c1.5 2.2 1.5 6-.8 9" />
          </svg>
          {c}
        </span>
      ))}
    </div>
  </div>

  <p class="sr-only">
    Internationally awarded black &amp; grey realism tattoo artist based in Dublin, Ireland.
  </p>
</section>

<style>
  .trophy {
    position: relative;
    z-index: 2;
    background: var(--ink);
    color: var(--paper-on-dark);
    padding-block: 1.05rem;
  }

  .trophy__item {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    font-family: var(--font-mono);
    font-size: var(--text-tiny);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-on-dark-soft);
    white-space: nowrap;
  }

  .trophy__laurel {
    color: var(--paper-on-dark);
    opacity: 0.75;
    flex: none;
  }
</style>
