<a href="#booking" id="sticky-book" class="sticky-book" aria-label="Book a consultation" data-magnetic data-magnetic-strength="0.4">
  <span class="sticky-book__inner">
    <span class="sticky-book__dot" aria-hidden="true"></span>
    Book
  </span>
</a>

<style>
  .sticky-book {
    position: fixed;
    right: clamp(1rem, 3vw, 2rem);
    bottom: clamp(1rem, 3vw, 2rem);
    z-index: 800;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1em 1.6em;
    font-family: var(--font-mono);
    font-size: var(--text-tiny);
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--paper);
    background: var(--ink);
    border-radius: 999px;
    box-shadow: 0 12px 34px -12px rgba(17, 17, 19, 0.55);
    opacity: 0;
    transform: translateY(14px) scale(0.96);
    pointer-events: none;
    transition:
      opacity 0.7s var(--ease-out-expo),
      transform 0.7s var(--ease-out-expo),
      box-shadow var(--dur) var(--ease);
  }

  .sticky-book.is-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  .sticky-book:hover {
    box-shadow: 0 16px 40px -12px rgba(17, 17, 19, 0.6);
  }

  .sticky-book__inner {
    display: inline-flex;
    align-items: center;
    gap: 0.6em;
  }

  .sticky-book__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--paper);
    animation: sticky-pulse 2.4s var(--ease-soft) infinite;
  }

  @keyframes sticky-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.8); }
  }

  @media (prefers-reduced-motion: reduce) {
    .sticky-book__dot {
      animation: none;
    }
  }
</style>

<script>
  const stickyBook = document.getElementById('sticky-book');
  const hero = document.getElementById('hero');

  if (stickyBook && hero) {
    const observer = new IntersectionObserver(([entry]) => {
      stickyBook.classList.toggle('is-visible', !entry.isIntersecting);
    });
    observer.observe(hero);
  } else {
    stickyBook?.classList.add('is-visible');
  }
</script>
