---
const links = [
  { href: '#portfolio', label: 'Portfolio' },
  { href: '#signature', label: 'Signature' },
  { href: '#about', label: 'About' },
  { href: '#process', label: 'Process' },
];
---

<header id="site-nav" class="site-nav">
  <div class="wrap site-nav__inner">
    <a href="#top" class="site-nav__mark">
      Luan Freitas<span class="site-nav__mark-dot">.</span>
    </a>

    <nav class="site-nav__links" aria-label="Primary">
      {links.map((l) => (
        <a href={l.href}><span>{l.label}</span></a>
      ))}
    </nav>

    <a href="#booking" class="btn btn--ink site-nav__cta" data-magnetic>Book</a>

    <button
      id="nav-toggle"
      class="site-nav__toggle"
      aria-expanded="false"
      aria-controls="nav-mobile"
      aria-label="Toggle menu"
    >
      <span></span>
      <span></span>
    </button>
  </div>

  <nav id="nav-mobile" class="site-nav__mobile" aria-label="Mobile">
    {links.map((l) => (
      <a href={l.href}>{l.label}</a>
    ))}
    <a href="#booking" class="site-nav__mobile-cta">Book a Consultation</a>
  </nav>
</header>

<style>
  .site-nav {
    position: fixed;
    inset-inline: 0;
    top: 0;
    z-index: 900;
    height: var(--nav-height);
    display: flex;
    align-items: center;
    background: transparent;
    border-bottom: 1px solid transparent;
    transition:
      background var(--dur) var(--ease),
      border-color var(--dur) var(--ease),
      backdrop-filter var(--dur) var(--ease);
  }

  .site-nav.is-scrolled {
    background: rgba(244, 242, 238, 0.78);
    backdrop-filter: blur(14px) saturate(1.2);
    border-bottom-color: var(--line-soft);
  }

  .site-nav__inner {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .site-nav__mark {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--ink);
  }

  .site-nav__mark-dot {
    color: var(--ink-faint);
  }

  .site-nav__links {
    display: none;
    align-items: center;
    gap: clamp(1.5rem, 3vw, 2.75rem);
    font-family: var(--font-mono);
    font-size: var(--text-tiny);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-mid);
  }

  .site-nav__links a {
    position: relative;
    padding-block: 0.4rem;
    overflow: hidden;
  }

  .site-nav__links a span {
    display: inline-block;
    transition: transform 0.45s var(--ease-out-expo);
  }

  .site-nav__links a::after {
    content: '';
    position: absolute;
    left: 0;
    right: 100%;
    bottom: 0;
    height: 1px;
    background: var(--metal-gradient);
    background-size: 4rem 100%;
    transition: right 0.5s var(--ease-out-expo);
  }

  .site-nav__links a:hover span {
    transform: translateY(-2px);
    color: var(--ink);
  }

  .site-nav__links a:hover::after {
    right: 0;
  }

  .site-nav__cta {
    display: none;
    padding: 0.65em 1.5em;
  }

  .site-nav__toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.5rem;
    height: 2.5rem;
  }

  .site-nav__toggle span {
    display: block;
    height: 1.5px;
    width: 100%;
    background: var(--ink);
    transition: transform 0.4s var(--ease), opacity 0.3s var(--ease);
  }

  .site-nav__toggle[aria-expanded='true'] span:first-child {
    transform: translateY(3.25px) rotate(45deg);
  }

  .site-nav__toggle[aria-expanded='true'] span:last-child {
    transform: translateY(-3.25px) rotate(-45deg);
  }

  .site-nav__mobile {
    position: fixed;
    inset: var(--nav-height) 0 0 0;
    background: rgba(244, 242, 238, 0.98);
    backdrop-filter: blur(12px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.75rem;
    font-family: var(--font-display);
    font-size: 2rem;
    transform: translateY(-10px);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--dur) var(--ease), transform var(--dur) var(--ease);
  }

  .site-nav__mobile.is-open {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .site-nav__mobile-cta {
    margin-top: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.9em 2em;
    background: var(--ink);
    color: var(--paper);
    border-radius: var(--radius);
  }

  @media (min-width: 900px) {
    .site-nav__links,
    .site-nav__cta {
      display: flex;
    }
    .site-nav__toggle {
      display: none;
    }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const mobile = document.getElementById('nav-mobile');

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    mobile?.classList.toggle('is-open', !expanded);
    document.body.style.overflow = !expanded ? 'hidden' : '';
  });

  mobile?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => {
      toggle?.setAttribute('aria-expanded', 'false');
      mobile.classList.remove('is-open');
      document.body.style.overflow = '';
    });
  });
</script>
