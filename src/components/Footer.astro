---
const links = [
  { href: '#portfolio', label: 'Portfolio' },
  { href: '#signature', label: 'Signature' },
  { href: '#about', label: 'About' },
  { href: '#process', label: 'Process' },
  { href: '#booking', label: 'Book' },
];
---

<footer class="site-footer bg-ink">
  <div class="wrap site-footer__inner">
    <div class="site-footer__top">
      <div class="site-footer__cta-block">
        <p class="site-footer__eyebrow">Ready when you are</p>
        <a href="#booking" class="site-footer__wordmark">
          <span class="metallic-text" data-sheen>Book a Consultation</span>
          <span class="site-footer__arrow" aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>

    <div class="metal-rule site-footer__rule" aria-hidden="true"></div>

    <div class="site-footer__grid">
      <span class="site-footer__mark">Luan Freitas</span>

      <nav class="site-footer__nav" aria-label="Footer">
        {links.map((l) => (
          <a href={l.href}>{l.label}</a>
        ))}
      </nav>

      <div class="site-footer__contact">
        <a href="https://instagram.com/luanfreitas_tattoo" target="_blank" rel="noopener noreferrer">
          @luanfreitas_tattoo
        </a>
        <p>[Placeholder: studio address]</p>
        <p>[Placeholder: studio hours]</p>
      </div>
    </div>

    <p class="site-footer__legal">&copy; {new Date().getFullYear()} Luan Freitas Tattoo, Dublin. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--ink);
    color: var(--paper-on-dark);
    padding-block: clamp(4rem, 9vw, 7rem) 2rem;
  }

  .site-footer__eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(243, 242, 239, 0.5);
  }

  .site-footer__wordmark {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    margin-top: 1rem;
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 4.5rem);
    font-weight: 600;
    line-height: 1;
  }

  .site-footer__arrow {
    font-size: 0.6em;
    color: rgba(243, 242, 239, 0.6);
    transition: transform 0.4s var(--ease-out-expo);
  }

  .site-footer__wordmark:hover .site-footer__arrow {
    transform: translateX(0.35em);
  }

  .site-footer__rule {
    margin-block: clamp(2.5rem, 5vw, 4rem);
    opacity: 0.5;
  }

  .site-footer__grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 2rem;
  }

  .site-footer__mark {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--paper-on-dark);
  }

  .site-footer__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    font-family: var(--font-mono);
    font-size: var(--text-tiny);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-on-dark-soft);
  }

  .site-footer__nav a {
    transition: color var(--dur) var(--ease);
  }

  .site-footer__nav a:hover {
    color: var(--paper-on-dark);
  }

  .site-footer__contact {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-size: var(--text-small);
    color: var(--ink-on-dark-soft);
    text-align: right;
  }

  .site-footer__contact a {
    color: var(--paper-on-dark);
  }

  .site-footer__legal {
    margin-top: clamp(2.5rem, 5vw, 4rem);
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.06em;
    color: rgba(243, 242, 239, 0.4);
    text-align: center;
  }
</style>
